{
  "name": "mcp-conduit",
  "version": "1.0.0",
  "description": "Production-grade MCP gateway with caching, guardrails, plugins, and multi-server routing",
  "type": "module",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "conduit": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/lacausecrypto/mcp-conduit.git"
  },
  "homepage": "https://github.com/lacausecrypto/mcp-conduit#readme",
  "bugs": {
    "url": "https://github.com/lacausecrypto/mcp-conduit/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "gateway",
    "proxy",
    "conduit",
    "cache",
    "rate-limiting",
    "auth",
    "guardrails",
    "plugins",
    "observability",
    "opentelemetry",
    "ai",
    "llm",
    "agent",
    "stdio",
    "claude",
    "tool-use"
  ],
  "scripts": {
    "build": "tsc && cp src/dashboard/index.html dist/dashboard/index.html",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:battle": "vitest run tests/battle/ --reporter=verbose",
    "test:integration": "vitest run tests/integration/ --reporter=verbose",
    "lint": "tsc --noEmit",
    "benchmark": "tsx tests/benchmark/full-benchmark.ts",
    "benchmark:quick": "tsx tests/benchmark/full-benchmark.ts --quick",
    "benchmark:json": "tsx tests/benchmark/full-benchmark.ts --json",
    "benchmark:legacy": "tsx tests/benchmark/benchmark.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-trace-node": "^2.6.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "better-sqlite3": "^11.9.1",
    "hono": "^4.7.7",
    "jose": "^5.10.0",
    "js-yaml": "^4.1.0",
    "lru-cache": "^11.0.2",
    "prom-client": "^15.1.3",
    "redis": "^5.11.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.14.0",
    "@vitest/coverage-v8": "^3.2.4",
    "playwright": "^1.59.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
