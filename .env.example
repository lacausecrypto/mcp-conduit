# Conduit — Environment Variables
# =======================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# WARNING: NEVER commit the .env file to git.
#          Make sure .env is in your .gitignore:
#            echo ".env" >> .gitignore
#
# Environment variables ALWAYS take precedence
# over conduit.config.yml. This is the recommended
# method for injecting secrets without committing them.
# =======================================

# -----------------------------------------
# Gateway
# -----------------------------------------

# Path to the YAML configuration file
# Default: conduit.config.yml in the current directory
CONDUIT_CONFIG=./conduit.config.yml

# Gateway listening port
# Default: 8080
CONDUIT_PORT=8080

# Listening address
# "0.0.0.0" = all network interfaces
# "127.0.0.1" = localhost only (more secure when behind a reverse proxy)
# Default: 0.0.0.0
CONDUIT_HOST=0.0.0.0

# -----------------------------------------
# Security — Admin API
# -----------------------------------------

# Bearer key to protect the admin API (/conduit/*)
# WARNING: REQUIRED in production
# Generate a random key: openssl rand -hex 32
# If empty: the admin API is accessible without authentication
CONDUIT_ADMIN_KEY=replace-with-a-random-key-of-at-least-32-characters

# -----------------------------------------
# TLS (optional)
# -----------------------------------------

# Enable native HTTPS (true/false)
# Alternative: place a reverse proxy (nginx, Caddy) in front
# Default: false
CONDUIT_TLS_ENABLED=false

# Path to the PEM certificate file
# Example with Let's Encrypt: /etc/letsencrypt/live/mydomain.com/fullchain.pem
CONDUIT_TLS_CERT=/path/to/cert.pem

# Path to the PEM private key file
# Example with Let's Encrypt: /etc/letsencrypt/live/mydomain.com/privkey.pem
CONDUIT_TLS_KEY=/path/to/key.pem

# -----------------------------------------
# Redis (optional — rate limiting + L2 cache)
# -----------------------------------------

# Redis connection URL for distributed rate limiting AND L2 cache
# Required if rate_limits.backend: redis or cache.l2.enabled: true
# Format: redis://[user:password@]host:port[/db]
# Examples:
#   redis://localhost:6379
#   redis://user:password@redis.example.com:6379/0
#   rediss://redis.example.com:6380  (with TLS)
CONDUIT_REDIS_URL=redis://localhost:6379

# -----------------------------------------
# Observability
# -----------------------------------------

# Path to the SQLite log database
# In production Docker/Kubernetes: use a persistent volume
# Example: /data/conduit-logs.db
# Default: ./conduit-logs.db
CONDUIT_DB_PATH=./conduit-logs.db

# Prometheus metrics server port
# Default: 9090
CONDUIT_METRICS_PORT=9090

# Log tool call arguments (true/false)
# Disable if arguments are large or contain sensitive data
# Default: true
CONDUIT_LOG_ARGS=true
